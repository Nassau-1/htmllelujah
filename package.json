{
  "name": "htmllelujah",
  "version": "1.0.0",
  "private": true,
  "description": "AI-native, local-first presentation editor for structured HTML slides.",
  "author": "Nassau-1",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm --workspace-concurrency=1 -r --if-present build",
    "build:packages": "pnpm --workspace-concurrency=1 --filter \"./packages/**\" -r --if-present build",
    "dev": "pnpm --filter @htmllelujah/desktop dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "licenses:check": "node scripts/check-licenses.mjs",
    "make:win": "node scripts/build-windows-release.mjs",
    "package:win": "node scripts/build-windows-release.mjs",
    "sbom:generate": "node scripts/generate-sbom.mjs",
    "test": "pnpm build:packages && pnpm --workspace-concurrency=1 -r --if-present test --pool=threads --maxWorkers=1",
    "test:release-evidence": "node scripts/test-release-evidence.mjs",
    "test:release-pipeline": "node --test --test-isolation=none scripts/windows-release-pipeline.test.mjs",
    "test:sbom-generate": "node --test scripts/generate-sbom.test.mjs",
    "typecheck": "pnpm build:packages && pnpm --workspace-concurrency=1 -r --if-present typecheck",
    "verify": "pnpm format:check && pnpm typecheck && pnpm test && pnpm test:release-evidence && pnpm test:release-pipeline && pnpm test:sbom-generate && pnpm build && pnpm licenses:check"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "license-checker-rseidelsohn": "5.0.1",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
