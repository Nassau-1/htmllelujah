{
  "name": "@htmllelujah/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "HTMLlelujah desktop presentation editor",
  "license": "UNLICENSED",
  "author": "Nassau-1",
  "homepage": "https://github.com/Nassau-1/htmllelujah",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "make": "pnpm build && electron-builder --win nsis --x64",
    "package": "pnpm build && electron-builder --dir --win --x64",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "@htmllelujah/collaboration": "workspace:*",
    "@htmllelujah/document-core": "workspace:*",
    "@htmllelujah/document-runtime": "workspace:*",
    "@htmllelujah/exporter": "workspace:*",
    "@htmllelujah/geometry": "workspace:*",
    "@htmllelujah/hdeck": "workspace:*",
    "@htmllelujah/mcp-server": "workspace:*",
    "@htmllelujah/renderer": "workspace:*",
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@electron/fuses": "2.1.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "vite": "8.1.4",
    "vite-plugin-electron": "1.1.0"
  },
  "build": {
    "appId": "app.htmllelujah.desktop",
    "productName": "HTMLlelujah",
    "asar": true,
    "artifactName": "HTMLlelujah-${version}-${arch}-Setup.${ext}",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/icon.png",
      "package.json"
    ],
    "fileAssociations": [
      {
        "ext": "hdeck",
        "name": "HTMLlelujah presentation",
        "description": "HTMLlelujah presentation",
        "role": "Editor",
        "icon": "assets/icon.ico"
      }
    ],
    "afterPack": "scripts/apply-fuses.mjs",
    "npmRebuild": false,
    "forceCodeSigning": false,
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "verifyUpdateCodeSignature": true
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "menuCategory": false
    }
  }
}
