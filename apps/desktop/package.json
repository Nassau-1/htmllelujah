{
  "name": "@htmllelujah/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "HTMLlelujah desktop presentation editor",
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "Nassau-1",
  "homepage": "https://github.com/Nassau-1/htmllelujah",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/write-build-provenance.mjs --prepare && vite build && node scripts/write-build-provenance.mjs --embed",
    "make": "node ../../scripts/build-windows-release.mjs",
    "package": "node ../../scripts/build-windows-release.mjs",
    "preview": "vite preview",
    "smoke:electron:exports": "pnpm build && node scripts/smoke-system-exports-windows.mjs",
    "smoke:electron:exports:stress": "pnpm build && node scripts/smoke-system-exports-windows.mjs --stress",
    "smoke:electron:mcp": "pnpm build && node scripts/smoke-mcp-electron.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "@htmllelujah/collaboration": "workspace:*",
    "@htmllelujah/document-core": "workspace:*",
    "@htmllelujah/document-runtime": "workspace:*",
    "@htmllelujah/exporter": "workspace:*",
    "@htmllelujah/geometry": "workspace:*",
    "@htmllelujah/hdeck": "workspace:*",
    "@htmllelujah/mcp-server": "workspace:*",
    "@htmllelujah/renderer": "workspace:*",
    "lucide-react": "1.26.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "tslib": "2.8.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@electron/fuses": "2.1.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "vite": "8.1.4",
    "vite-plugin-electron": "1.1.0"
  },
  "build": {
    "appId": "app.htmllelujah.desktop",
    "productName": "HTMLlelujah",
    "asar": true,
    "artifactName": "HTMLlelujah-${version}-${arch}-unsigned-Setup.${ext}",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/icon.png",
      "package.json",
      "!**/*.map",
      "!node_modules/**/*"
    ],
    "extraFiles": [
      {
        "from": "assets/HTMLlelujah-MCP.cmd",
        "to": "HTMLlelujah-MCP.cmd"
      },
      {
        "from": "../../LICENSE",
        "to": "LICENSE.txt"
      },
      {
        "from": "../../COMMERCIAL-LICENSING.md",
        "to": "COMMERCIAL-LICENSING.md"
      },
      {
        "from": "../../THIRD_PARTY_NOTICES.md",
        "to": "THIRD_PARTY_NOTICES.md"
      }
    ],
    "fileAssociations": [
      {
        "ext": "hdeck",
        "name": "HTMLlelujah presentation",
        "description": "HTMLlelujah presentation",
        "role": "Editor"
      }
    ],
    "afterPack": "scripts/apply-fuses.mjs",
    "npmRebuild": false,
    "forceCodeSigning": false,
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "verifyUpdateCodeSignature": true
    },
    "nsis": {
      "guid": "7bf3c6ec-651b-477c-a0b7-399160cda612",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "packElevateHelper": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "include": "scripts/installer-association.nsh",
      "license": "../../LICENSE",
      "menuCategory": false
    }
  }
}
