{
  "name": "htmllelujah",
  "version": "0.1.0",
  "private": true,
  "description": "AI-native, local-first presentation editor for structured HTML slides.",
  "author": "Nassau-1",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --filter @htmllelujah/desktop dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "licenses:check": "node scripts/check-licenses.mjs",
    "sbom:generate": "pnpm sbom --sbom-format cyclonedx --prod --sbom-type application > artifacts/sbom.cdx.json",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "verify": "pnpm format:check && pnpm typecheck && pnpm test && pnpm build && pnpm licenses:check"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "license-checker-rseidelsohn": "5.0.1",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
